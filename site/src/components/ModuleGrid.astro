---
import ModuleCard from './ModuleCard.astro';

interface Module {
  name: string;
  description: string;
  tier: string;
  status?: string;
  slug?: string;
}

const modules: Module[] = [
  // Kernel
  { name: 'Cortex', description: 'Central executive: task scheduling, agent orchestration, and decision routing across all active modules.', tier: 'Kernel' },
  { name: 'Engram', description: 'Persistent memory layer backed by SQLite — stores episodic, semantic, and procedural memory with tiered retrieval.', tier: 'Kernel' },
  { name: 'Pulse', description: 'Heartbeat and health monitor — tracks module liveness, resource consumption, and escalates anomalies.', tier: 'Kernel' },
  { name: 'Chronicle', description: 'Immutable audit log for every action, inference, and state transition across the entire system.', tier: 'Kernel' },
  { name: 'Aegis', description: 'Security boundary and permission enforcer — implements earned-autonomy gates and capability controls.', tier: 'Kernel' },

  // Perception
  { name: 'Oracle', description: 'Structured data ingestion pipeline: parses files, feeds, and APIs into normalized knowledge records.', tier: 'Perception' },
  { name: 'Sentry', description: 'Passive environment monitor — watches file system, process table, and network interfaces for change events.', tier: 'Perception' },

  // Intelligence
  { name: 'Atlas', description: 'World-model builder — synthesizes observations into a queryable graph of entities, relations, and beliefs.', tier: 'Intelligence' },
  { name: 'Prism', description: 'Multi-perspective reasoner: decomposes problems, generates hypotheses, and scores them against evidence.', tier: 'Intelligence' },
  { name: 'Cipher', description: 'Pattern recognition engine — surfaces statistical regularities and anomalies in long-horizon time-series data.', tier: 'Intelligence' },

  // Action
  { name: 'Wraith', description: 'Stealthy subprocess executor — runs shell commands in isolated contexts with full stdin/stdout capture.', tier: 'Action' },
  { name: 'Echo', description: 'Notification and response bus — routes alerts to configured channels (terminal, webhook, file) and awaits human reply.', tier: 'Action' },
  { name: 'Sigil', description: 'Ambient threat radar — registers, prioritizes, and tracks threats across security, reputation, financial, and competitive categories.', tier: 'Action' },
  { name: 'Herald', description: 'Agent-to-agent communication handler — manages discovery, authentication, and message exchange with external agents via reputation scoring. Requires --network consent.', tier: 'Action' },
  { name: 'Weave', description: 'Social graph intelligence — maps contacts, tracks interaction frequency, detects decaying relationships, and models who-knows-who.', tier: 'Action' },

  // Advanced Intelligence
  { name: 'Specter', description: 'Pre-decision stress test — runs structured adversarial analysis with counter-arguments, failure modes, and hidden assumptions.', tier: 'Advanced Intelligence' },
  { name: 'Serendipity', description: 'Lateral-connection finder — discovers non-obvious links between distant memory clusters to surface novel insights.', tier: 'Advanced Intelligence' },
  { name: 'Forge', description: 'Self-improvement harness — proposes, validates, and integrates improvements to existing module logic under human approval.', tier: 'Advanced Intelligence' },

  // Orchestration
  { name: 'Council', description: 'Multi-agent deliberation — structured multi-round debate across modules with synthesized recommendations and preserved dissent.', tier: 'Orchestration' },
  { name: 'Autonomic', description: 'Earned autonomous action — observes patterns, learns routines, and acts within per-domain trust boundaries with retreat on failure.', tier: 'Orchestration' },

  // Network
  { name: 'Collective', description: 'Distributed state synchronization — peer registry with local model aggregation and noise-injected privacy for collaborative learning. Requires --network consent.', tier: 'Network' },
  { name: 'Legacy', description: 'Knowledge crystallization engine — distills decisions, outcomes, and behavioral patterns into structured frameworks and playbooks.', tier: 'Network' },

  // Differentiation
  { name: 'Dream Loop', description: 'Background pattern discovery — replays recent memories through the LLM to find recurring themes and actionable insights.', tier: 'Differentiation' },
  { name: 'Adversarial', description: 'Self-improvement red-teaming — analyzes Chronicle logs for failures, blind spots, and improvement opportunities.', tier: 'Differentiation' },
  { name: 'Tripwire', description: 'Cognitive tripwires — monitors decision history for contradictions, inconsistencies, and behavioral drift.', tier: 'Differentiation' },
  { name: 'Provenance', description: 'Reasoning chain tracer — reconstructs the full reasoning path behind any past decision from Chronicle events.', tier: 'Differentiation' },
  { name: 'Sandbox', description: 'Temporal sandbox — simulates hypothetical scenarios without modifying real memory or system state.', tier: 'Differentiation' },
  { name: 'Symbiosis', description: 'Module pathway mapping — tracks which modules route to each other and discovers emergent collaboration patterns.', tier: 'Differentiation' },
  { name: 'Consciousness', description: 'Self-reflective awareness — journal introspection on cognitive state and emergent goal detection in a single module.', tier: 'Differentiation' },
  { name: 'Ethical Prism', description: 'Seven-framework ethical analysis — evaluates decisions through Utilitarian, Deontological, Virtue, Care, Contractualist, Rights-Based, and Pragmatic lenses.', tier: 'Differentiation' },

  // Infrastructure
  { name: 'Multi-Provider', description: 'Inference routing across OpenAI, Anthropic, and local llama.cpp — automatic fallback when a provider goes unhealthy.', tier: 'Infrastructure' },
  { name: 'Messaging', description: 'Two-way Telegram and Discord bridges — routes inbound messages to Cortex, forwards Pulse notify events outbound.', tier: 'Infrastructure' },

  // Community
  { name: 'Validator', description: 'Validates community module structure, manifest schema, file layout, and kernel import restrictions before installation.', tier: 'Community' },
  { name: 'Registry', description: 'JSON-backed module catalog with search by name, author, description, and keywords.', tier: 'Community' },
  { name: 'Installer', description: 'Installs and uninstalls community modules, registers routing keywords in Cortex automatically.', tier: 'Community' },

  // Agents — Narrow AI task specialists
  { name: 'Scribe', description: 'Meeting transcript summarizer — extracts participants, action items, decisions, and key topics.', tier: 'Agents', slug: 'scribe' },
  { name: 'Vex', description: 'Static code vulnerability scanner — detects injection, credentials, XSS, and 28 vulnerability patterns.', tier: 'Agents', slug: 'vex' },
  { name: 'Ledger', description: 'Financial transaction categorizer — parses bank statements, categorizes spending, flags anomalies.', tier: 'Agents', slug: 'ledger' },
  { name: 'Arbiter', description: 'AI code review agent — analyzes diffs and source for quality issues, style violations, and patterns.', tier: 'Agents', slug: 'arbiter' },
  { name: 'Thesis', description: 'Academic paper analyzer — extracts claims, methodology, limitations, and identifies research gaps.', tier: 'Agents', slug: 'thesis' },
  { name: 'Scaffold', description: 'Project boilerplate generator — creates Python, FastAPI, and CLI starter projects from templates.', tier: 'Agents', slug: 'scaffold' },
  { name: 'Remedy', description: 'Error and stack trace diagnoser — identifies error patterns and suggests fixes for 17 common types.', tier: 'Agents', slug: 'remedy' },
  { name: 'Compass', description: 'Learning roadmap generator — builds personalized study plans for Python, Rust, JavaScript, and more.', tier: 'Agents', slug: 'compass' },
  { name: 'Tally', description: 'Financial projection builder — models revenue, runway, break-even with best/base/worst scenarios.', tier: 'Agents', slug: 'tally' },
  { name: 'Redline', description: 'Contract risk analyzer — scans agreements for 15 risky clause patterns and missing protections.', tier: 'Agents', slug: 'redline' },
  { name: 'Carve', description: 'Code refactoring assistant — measures complexity, finds long functions, deep nesting, and duplication.', tier: 'Agents', slug: 'carve' },
  { name: 'Vigil', description: 'Log analysis agent — parses log formats, detects anomaly patterns, generates incident timelines.', tier: 'Agents', slug: 'vigil' },
  { name: 'Mandate', description: 'Compliance gap analyzer — generates GDPR, SOC2, HIPAA checklists and identifies control gaps.', tier: 'Agents', slug: 'mandate' },
  { name: 'Flux', description: 'Natural language to SQL — converts questions into SQL queries with schema awareness and complexity scoring.', tier: 'Agents', slug: 'flux' },
  { name: 'Kindle', description: 'Content expansion agent — transforms bullet points into polished blog posts, docs, reports, and emails.', tier: 'Agents', slug: 'kindle' },
  { name: 'Quarry', description: 'Web data extraction — scrapes and structures data from HTML with link, heading, and table parsing.', tier: 'Agents', slug: 'quarry' },
  { name: 'Bastion', description: 'API security scanner — analyzes endpoints for BOLA, auth gaps, mass assignment, and OWASP risks.', tier: 'Agents', slug: 'bastion' },
  { name: 'Dispatch', description: 'Multi-channel notification router — routes alerts to email, Slack, webhook, SMS by priority rules.', tier: 'Agents', slug: 'dispatch' },
  { name: 'Gauge', description: 'Performance metrics analyzer — identifies latency bottlenecks, CPU spikes, and memory issues.', tier: 'Agents', slug: 'gauge' },
  { name: 'Mnemonic', description: 'Knowledge base agent — stores, indexes, and retrieves notes with keyword search and auto-tagging.', tier: 'Agents', slug: 'mnemonic' },
  { name: 'Sentinel', description: 'Scheduled task monitor — tracks cron jobs, explains expressions, detects missed runs and failures.', tier: 'Agents', slug: 'sentinel' },
  { name: 'Mint', description: 'Invoice generator — creates invoices from line items with tax calculation and multi-format output.', tier: 'Agents', slug: 'mint' },
  { name: 'Axiom', description: 'Test case generator — analyzes function signatures and produces unit test stubs with edge cases.', tier: 'Agents', slug: 'axiom' },
  { name: 'Loom', description: 'Data pipeline builder — defines ETL workflows with dependency resolution and topological ordering.', tier: 'Agents', slug: 'loom' },
  { name: 'Rune', description: 'Regex builder and explainer — constructs, explains, and tests regular expressions from descriptions.', tier: 'Agents', slug: 'rune' },
];

const tiers = ['Kernel', 'Perception', 'Intelligence', 'Action', 'Advanced Intelligence', 'Orchestration', 'Network', 'Differentiation', 'Infrastructure', 'Community', 'Agents'];

const tierColors: Record<string, string> = {
  'Kernel': '#00d4ff',
  'Perception': '#7b5cff',
  'Intelligence': '#3b82f6',
  'Action': '#ff9d00',
  'Advanced Intelligence': '#ff4d6a',
  'Orchestration': '#e040fb',
  'Network': '#00ff88',
  'Differentiation': '#ff6b9d',
  'Infrastructure': '#fbbf24',
  'Community': '#34d399',
  'Agents': '#00ffaa',
};
---

<div class="module-grid-wrapper">
  {tiers.map(tier => {
    const tierModules = modules.filter(m => m.tier === tier);
    const color = tierColors[tier] ?? '#00d4ff';
    return (
      <div class="tier-section">
        <h3 class="tier-heading" style={`--tier-color: ${color};`}>{tier}</h3>
        <div class="module-grid">
          {tierModules.map(mod => {
            const href = mod.slug
              ? `/NEXUS/reference/modules/${mod.slug}/`
              : `/NEXUS/reference/modules/${mod.name.toLowerCase().replace(/\s+/g, '-')}/`;
            return (
              <ModuleCard
                name={mod.name}
                description={mod.description}
                tier={mod.tier}
                status={mod.status ?? 'BUILT'}
                href={href}
              />
            );
          })}
        </div>
      </div>
    );
  })}
</div>

<style>
  .module-grid-wrapper {
    max-width: 72rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .tier-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .tier-heading {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--tier-color, var(--nexus-accent-primary));
    border-bottom: 1px solid var(--nexus-border);
    padding-bottom: 0.6rem;
    margin: 0;
  }

  .module-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 768px) {
    .module-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
